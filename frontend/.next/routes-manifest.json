{
  "version": 3,
  "pages404": true,
  "appType": "pages",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/admin/AdminDash",
      "regex": "^/admin/AdminDash(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/AdminDash(?:/)?$"
    },
    {
      "page": "/driver/DriverDash",
      "regex": "^/driver/DriverDash(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/driver/DriverDash(?:/)?$"
    },
    {
      "page": "/Landing",
      "regex": "^/Landing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/Landing(?:/)?$"
    },
    {
      "page": "/passenger/PassengerDash",
      "regex": "^/passenger/PassengerDash(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/passenger/PassengerDash(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}