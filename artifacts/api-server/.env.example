# MySQL Database — use the PUBLIC Railway proxy host, not the internal .railway.internal one
DB_PUBLIC_HOST=zephyr.proxy.rlwy.net
DB_PORT=25153
DB_USER=your-mysql-user
DB_PASS=your-mysql-password
DB_NAME=your-database-name

# JWT secret for admin tokens — set a strong random string in production
JWT_SECRET=waslney_admin_super_secret_change_me_in_production

# Server port (Replit sets this automatically via artifact config)
# PORT=8080
